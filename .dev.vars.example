# === Kredensial Tuya Cloud (JANGAN commit file .dev.vars asli) ===
# File ini adalah "template". Salin ke `.dev.vars` untuk dev lokal (wrangler otomatis membacanya),
# dan saat deploy ke Cloudflare, set nilai-nilai ini sebagai SECRET (lihat README).

# Dari Tuya IoT Platform > Cloud > Development > (project kamu) > Overview
TUYA_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
TUYA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint region data center Tuya kamu. Pilih salah satu:
#   https://openapi.tuyaus.com   (Amerika)
#   https://openapi.tuyaeu.com   (Eropa)
#   https://openapi.tuyain.com   (India)
#   https://openapi.tuyacn.com   (China)
TUYA_BASE_URL=https://openapi.tuyaus.com

# UID akun App Tuya (bukan Client ID!) yang di-link ke Cloud Project kamu
# (Cloud > Devices > Link Tuya App Account > klik baris akun "budi.purwanto15@gmail.com" untuk lihat UID).
# Dengan ini, SEMUA device yang ter-link otomatis muncul di dashboard — tidak perlu ketik Device ID satu-satu.
TUYA_UID=az17xxxxxxxxxxxxxxxx

# Device ID perangkat berdaya tinggi untuk fitur Idle Alerts (Water Heater, AC), dipisah koma
# (untuk ini tetap perlu Device ID manual karena cuma sebagian device yang mau dipantau borosnya)
HIGH_POWER_DEVICE_IDS=waterheaterid,acid

# Batas idle dalam menit sebelum alert muncul (default 60)
IDLE_LIMIT_MINUTES=60

# Koordinat rumah untuk cek cuaca (Open-Meteo, gratis tanpa API key). Contoh: Jakarta
HOME_LATITUDE=-6.2088
HOME_LONGITUDE=106.8456
